<Window x:Class="ControllerWarcraft.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight">

    <!-- Pannello arrotondato semitrasparente. Colore e testi impostati da code-behind
         in base allo stato (modalità/layer/pausa). -->
    <Border x:Name="RootBorder" CornerRadius="10" Padding="16,9"
            Background="#DD1B5E20" BorderBrush="#66FFFFFF" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
        </Border.Effect>
        <StackPanel>
            <TextBlock x:Name="ModeText"
                       Text="MOVIMENTO/COMBATTIMENTO"
                       Foreground="White" FontFamily="Segoe UI" FontWeight="Bold"
                       FontSize="15" HorizontalAlignment="Center" />
            <TextBlock x:Name="LayerText"
                       Text="BASE (1-9)"
                       Foreground="#DDFFFFFF" FontFamily="Segoe UI" FontSize="12"
                       HorizontalAlignment="Center" Margin="0,2,0,0" />
            <TextBlock x:Name="ProfileText"
                       Text=""
                       Foreground="#AAFFFFFF" FontFamily="Segoe UI" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,3,0,0" />
            <TextBlock x:Name="CompanionText"
                       Text=""
                       Foreground="#CCFFE082" FontFamily="Segoe UI" FontSize="10"
                       HorizontalAlignment="Center" Margin="0,2,0,0" />
        </StackPanel>
    </Border>
</Window>
