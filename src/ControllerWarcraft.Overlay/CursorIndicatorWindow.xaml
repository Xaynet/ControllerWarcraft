<Window x:Class="ControllerWarcraft.Overlay.CursorIndicatorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">

    <!-- Indicatore EVIDENTE della modalità cursore: una cornice colorata ai bordi dello schermo
         + un badge in alto al centro. Click-through: non intercetta il mouse, non ruba il focus.
         Copre l'intero schermo primario; la cornice ha solo il bordo (nessun riempimento) per non
         coprire il gioco. -->
    <Grid>
        <!-- Cornice esterna spessa (colore acceso) -->
        <Border x:Name="OuterFrame" BorderBrush="#EE29B6F6" BorderThickness="4" />
        <!-- Cornice interna più tenue: dà profondità e la rende inconfondibile -->
        <Border BorderBrush="#5529B6F6" BorderThickness="1" Margin="4" />

        <!-- Badge in alto al centro -->
        <Border x:Name="Badge" VerticalAlignment="Top" HorizontalAlignment="Center"
                Margin="0,14,0,0" CornerRadius="8" Padding="14,6"
                Background="#EE0D47A1" BorderBrush="#66FFFFFF" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect Color="#000000" BlurRadius="12" ShadowDepth="0" Opacity="0.5" />
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🖱" FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center" />
                <TextBlock Text="MODALITÀ CURSORE"
                           Foreground="White" FontFamily="Segoe UI" FontWeight="Bold"
                           FontSize="14" VerticalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
